# ============================================================
# The CISO Council — .gitignore
# Security-first: nothing sensitive ever reaches the repo
# ============================================================

# ----- API Keys and Secrets -----
.env
.env.*
!.env.example
config.yaml
!config.yaml.example
secrets/
*.key
*.pem

# ----- Council Outputs (may contain sensitive scenario context) -----
outputs/*
!outputs/.gitkeep

# ----- Python -----
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg
.eggs/
*.whl
pip-log.txt
pip-delete-this-directory.txt

# ----- Virtual Environments -----
venv/
.venv/
env/
ENV/

# ----- IDE -----
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ----- Testing -----
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# ----- Claude Code -----
.claude/

# ----- Misc -----
*.log
*.tmp
.cache/
