# ============================================================
# The CISO Council — Environment Variables
# ============================================================
# Copy this file to .env and fill in your keys.
# NEVER commit .env — it is gitignored.
# ============================================================

# ============================================================
# PRODUCTION MODELS (Recommended for serious use)
# These providers give you frontier reasoning quality.
# ============================================================

# Anthropic — Claude Opus 4, Claude Sonnet 4.6
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI — GPT-4o, o3
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# xAI — Grok-3
# Get your key: https://console.x.ai/
XAI_API_KEY=your_xai_api_key_here

# ============================================================
# FREE TIER MODELS (Good starting point)
# All of these have generous free tiers.
# ============================================================

# Google Gemini — gemini-2.5-flash, gemini-2.5-pro (also used for scoring)
# Get your key: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Groq — llama-3.3-70b-versatile (extremely fast inference)
# Get your key: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Mistral AI — mistral-small-latest (1B tokens/month free)
# Get your key: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your_mistral_api_key_here

# OpenRouter — access to 24+ free models with one key
# Get your key: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# DeepSeek — strong reasoning, competitive pricing
# Get your key: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Cerebras — fast Llama inference
# Get your key: https://cloud.cerebras.ai/platform
CEREBRAS_API_KEY=your_cerebras_api_key_here

# ============================================================
# OPTIONAL: Override the scoring model
# Default: gemini-2.5-flash (fast, accurate, free)
# ============================================================
# SCORING_PROVIDER=google
# SCORING_MODEL=gemini-2.5-flash
