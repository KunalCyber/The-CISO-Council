# ============================================================
# The CISO Council — Configuration
# ============================================================
# Copy this file to config.yaml and edit as needed.
# NEVER commit config.yaml — it is gitignored.
# ============================================================

# ============================================================
# FREE TIER SETUP (Active by default — works out of the box)
# Start here. Upgrade to the production section when ready.
# ============================================================

council:
  members:
    - persona: ciso_fintech_startup
      provider: google
      model: gemini-2.5-flash
      enabled: true

    - persona: dpo_healthtech
      provider: groq
      model: llama-3.3-70b-versatile
      enabled: true

    - persona: cro_regulated_bank
      provider: mistral
      model: mistral-small-latest
      enabled: true

    - persona: internal_auditor_manufacturing
      provider: groq
      model: mixtral-8x7b-32768
      enabled: true

    - persona: ciso_enterprise_saas
      provider: google
      model: gemini-2.5-flash-lite-preview-06-17
      enabled: true

    - persona: ai_governance_lead
      provider: cerebras
      model: llama3.1-8b
      enabled: true

# ============================================================
# PRODUCTION SETUP (Recommended — uncomment to activate)
# Using frontier models produces significantly better council
# deliberations. Each member reasons more deeply, gives more
# specific recommendations, and the consensus/dissent analysis
# becomes genuinely useful for real decision-making.
# ============================================================

# council:
#   members:
