# ============================================================
# Scoring model — evaluates each council response
# ============================================================
scoring:
  provider: google
  model: gemini-2.5-flash
  dimensions:
    - regulatory_defensibility
    - practicality
    - board_readiness
    - specificity
    - risk_quantification

# ============================================================
# Rate limiting (requests per minute per provider)
# Tune these to stay within free tier limits.
# ============================================================
rate_limits:
  google: 5
  groq: 20
  mistral: 5
  openrouter: 10
  openai: 3
  anthropic: 5
  xai: 10
  deepseek: 5
  cerebras: 10

# ============================================================
# Output settings
# ============================================================
output:
  format: both          # markdown, json, or both
  directory: outputs
  include_raw: true
  include_scores: true

# ============================================================
# Session settings
# ============================================================
session:
  timeout: 120          # seconds per model call
  retries: 3
  concurrent: false     # set true only if your rate limits allow it
